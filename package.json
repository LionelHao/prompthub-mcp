{
  "name": "prompthub-mcp",
  "version": "0.1.0",
  "description": "MCP server for PromptHub — publish and fetch prompts from Claude Code / Codex.",
  "type": "module",
  "bin": { "prompthub-mcp": "./dist/index.js" },
  "engines": { "node": ">=18" },
  "repository": { "type": "git", "url": "git+https://github.com/LionelHao/prompthub-mcp.git" },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "vitest run",
    "verify": "tsc --noEmit && vitest run",
    "sync-skill": "node scripts/sync-skill.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29",
    "zod": "^3.25"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5.6",
    "vitest": "^2.1"
  }
}
